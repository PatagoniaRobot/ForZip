<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:ForZip.GUI.ViewModels"
             xmlns:views="clr-namespace:ForZip.GUI.Views"
             x:Class="ForZip.GUI.App"
             RequestedThemeVariant="Dark">

  <Application.Resources>
    <ResourceDictionary>
      <ResourceDictionary.ThemeDictionaries>
        <ResourceInclude x:Key="Dark" Source="/Styles/DarkTheme.axaml"/>
        <ResourceInclude x:Key="Light" Source="/Styles/LightTheme.axaml"/>
      </ResourceDictionary.ThemeDictionaries>
    </ResourceDictionary>
  </Application.Resources>

  <Application.Styles>
    <FluentTheme/>
  </Application.Styles>

  <Application.DataTemplates>
    <DataTemplate DataType="vm:ZipViewModel">
      <views:ZipView/>
    </DataTemplate>
    <DataTemplate DataType="vm:UnzipViewModel">
      <views:UnzipView/>
    </DataTemplate>
    <DataTemplate DataType="vm:HashBatchViewModel">
      <views:HashBatchView/>
    </DataTemplate>
    <DataTemplate DataType="vm:VerifyReportViewModel">
      <views:VerifyReportView/>
    </DataTemplate>
    <DataTemplate DataType="vm:PasswordGeneratorViewModel">
      <views:PasswordGeneratorView/>
    </DataTemplate>
    <DataTemplate DataType="vm:SettingsViewModel">
      <views:SettingsView/>
    </DataTemplate>
    <DataTemplate DataType="vm:AboutViewModel">
      <views:AboutView/>
    </DataTemplate>
  </Application.DataTemplates>
</Application>
