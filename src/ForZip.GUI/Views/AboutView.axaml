<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:ForZip.GUI.ViewModels"
             x:Class="ForZip.GUI.Views.AboutView"
             x:DataType="vm:AboutViewModel">

  <ScrollViewer>
    <StackPanel Spacing="14" Margin="4" HorizontalAlignment="Center" MaxWidth="600">

      <TextBlock Text="ACERCA DE"
                 FontSize="16" FontWeight="SemiBold"
                 Foreground="{DynamicResource TextPrimaryBrush}"
                 HorizontalAlignment="Left"/>

      <Border BorderBrush="{DynamicResource BorderBrush}"
              BorderThickness="1"
              CornerRadius="8"
              Width="128" Height="128"
              Background="{DynamicResource BgCardBrush}"
              HorizontalAlignment="Center">
        <TextBlock Text="📦🔍"
                   FontSize="48"
                   Foreground="{DynamicResource AccentBrush}"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"/>
      </Border>

      <TextBlock Text="{Binding AppName, StringFormat='{}{0}'}"
                 FontSize="20" FontWeight="Bold"
                 HorizontalAlignment="Center"
                 Foreground="{DynamicResource TextPrimaryBrush}"/>
      <TextBlock Text="{Binding Version}"
                 FontSize="14"
                 HorizontalAlignment="Center"
                 Foreground="{DynamicResource TextSecondaryBrush}"/>
      <TextBlock Text="{Binding Subtitle}"
                 FontSize="13"
                 HorizontalAlignment="Center"
                 Foreground="{DynamicResource TextSecondaryBrush}"/>

      <Separator Background="{DynamicResource BorderBrush}"/>

      <Grid ColumnDefinitions="120,*" RowDefinitions="Auto,Auto,Auto,Auto" Margin="0,4">
        <TextBlock Grid.Row="0" Grid.Column="0" Text="Autor:"
                   Foreground="{DynamicResource TextSecondaryBrush}"/>
        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Author}"
                   Foreground="{DynamicResource TextPrimaryBrush}"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="Email:"
                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0"/>
        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Email}"
                   Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,4,0,0"/>

        <TextBlock Grid.Row="2" Grid.Column="0" Text="Licencia:"
                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0"/>
        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding LicenseName}"
                   Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,4,0,0"/>

        <TextBlock Grid.Row="3" Grid.Column="0" Text="Iniciativa:"
                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0"/>
        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding Initiative}"
                   Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,4,0,0"/>
      </Grid>

      <Border BorderBrush="{DynamicResource BorderBrush}"
              BorderThickness="1"
              CornerRadius="4"
              Padding="16"
              Background="{DynamicResource BgCardBrush}">
        <StackPanel Spacing="6">
          <TextBlock Text="AVISO LEGAL"
                     FontWeight="SemiBold"
                     Foreground="{DynamicResource TextPrimaryBrush}"/>
          <TextBlock Text="{Binding DisclaimerText}"
                     Foreground="{DynamicResource TextSecondaryBrush}"
                     TextWrapping="Wrap"
                     FontSize="12"/>
        </StackPanel>
      </Border>

      <StackPanel Orientation="Horizontal"
                  Spacing="8"
                  HorizontalAlignment="Center">
        <Button Content="Guía ForZip"
                Command="{Binding OpenHelpCommand}"
                Padding="16,8"/>
        <Button Content="Sitio web"
                Command="{Binding OpenWebsiteCommand}"
                Padding="16,8"/>
      </StackPanel>

    </StackPanel>
  </ScrollViewer>
</UserControl>
