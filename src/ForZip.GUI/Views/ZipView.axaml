<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:ForZip.GUI.ViewModels"
             x:Class="ForZip.GUI.Views.ZipView"
             x:DataType="vm:ZipViewModel"
             DragDrop.AllowDrop="True">

  <ScrollViewer>
    <Panel Margin="4">

      <!-- ================== PANTALLA DE RESULTADO ================== -->
      <StackPanel Spacing="12" IsVisible="{Binding IsResultVisible}">

        <TextBlock Text="{Binding Title}"
                   FontSize="16" FontWeight="SemiBold"
                   Foreground="{DynamicResource TextPrimaryBrush}"/>

        <Border BorderBrush="{DynamicResource AccentBrush}"
                BorderThickness="1"
                CornerRadius="6"
                Padding="20"
                Background="{DynamicResource BgCardBrush}">
          <StackPanel Spacing="14">

            <StackPanel Orientation="Horizontal" Spacing="10">
              <TextBlock Text="✔" FontSize="22"
                         Foreground="{DynamicResource AccentBrush}"
                         VerticalAlignment="Center"/>
              <TextBlock Text="{Binding ResultTitle}"
                         FontSize="18" FontWeight="Bold"
                         Foreground="{DynamicResource AccentBrush}"
                         VerticalAlignment="Center"/>
            </StackPanel>

            <TextBlock Text="{Binding ResultSubtitle}"
                       TextWrapping="Wrap"
                       Foreground="{DynamicResource TextSecondaryBrush}"/>

            <TextBlock Text="{Binding ResultNote}"
                       TextWrapping="Wrap"
                       Foreground="{DynamicResource WarningBrush}"
                       IsVisible="{Binding ResultNote, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

            <ItemsControl ItemsSource="{Binding ResultArtifacts}">
              <ItemsControl.ItemTemplate>
                <DataTemplate DataType="vm:ResultArtifactItem">
                  <Grid ColumnDefinitions="36,*" Margin="0,6">
                    <TextBlock Grid.Column="0" Text="{Binding Icon}"
                               FontSize="18"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Top"/>
                    <StackPanel Grid.Column="1" Spacing="2">
                      <TextBlock Text="{Binding FileName}"
                                 FontWeight="SemiBold"
                                 Foreground="{DynamicResource TextPrimaryBrush}"
                                 TextTrimming="CharacterEllipsis"/>
                      <TextBlock Text="{Binding Description}"
                                 TextWrapping="Wrap"
                                 FontSize="12"
                                 Foreground="{DynamicResource TextSecondaryBrush}"/>
                    </StackPanel>
                  </Grid>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>

            <StackPanel Spacing="4"
                        IsVisible="{Binding ResultZipHash, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
              <TextBlock Text="{Binding LabelResultHash}"
                         FontWeight="SemiBold"
                         Foreground="{DynamicResource TextSecondaryBrush}"/>
              <Grid ColumnDefinitions="*,Auto">
                <TextBox Grid.Column="0"
                         Text="{Binding ResultZipHash}"
                         IsReadOnly="True"
                         FontFamily="Consolas,monospace"
                         FontSize="12"/>
                <Button Grid.Column="1"
                        Content="{Binding LabelCopyHash}"
                        Command="{Binding CopyResultHashCommand}"
                        Margin="8,0,0,0"/>
              </Grid>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,6,0,0">
              <Button Content="{Binding LabelOpenFolder}"
                      Command="{Binding OpenResultFolderCommand}"
                      Background="{DynamicResource AccentBrush}"
                      Foreground="White"
                      Padding="16,8"/>
              <Button Content="{Binding LabelNewJob}"
                      Command="{Binding NewJobCommand}"
                      Padding="16,8"/>
            </StackPanel>

          </StackPanel>
        </Border>
      </StackPanel>

      <!-- ================== FORMULARIO DE EMPAQUETADO ================== -->
      <StackPanel Spacing="12" IsVisible="{Binding !IsResultVisible}">

        <DockPanel>
          <ToggleSwitch DockPanel.Dock="Right"
                        IsChecked="{Binding IsSimpleMode}"
                        OnContent="{Binding LabelModeSimple}"
                        OffContent="{Binding LabelModeAdvanced}"/>
          <TextBlock Text="{Binding Title}"
                     FontSize="16" FontWeight="SemiBold"
                     Foreground="{DynamicResource TextPrimaryBrush}"
                     VerticalAlignment="Center"/>
        </DockPanel>

        <TextBlock Text="{Binding LabelSimpleHint}"
                   TextWrapping="Wrap"
                   Foreground="{DynamicResource TextSecondaryBrush}"
                   IsVisible="{Binding IsSimpleMode}"/>

        <Border x:Name="DropZone"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                Background="Transparent"
                CornerRadius="4"
                Padding="24"
                MinHeight="100">
          <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="4">
            <TextBlock Text="{Binding LabelDropZone}"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"/>
              <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="8" Margin="0,8,0,0">
                <Button x:Name="BrowseFilesButton"
                        Content="{Binding LabelBrowseFiles}"
                        Click="OnBrowseFilesClick"/>
                <Button x:Name="BrowseFolderButton"
                        Content="{Binding LabelBrowseFolder}"
                        Click="OnBrowseFolderClick"/>
              </StackPanel>
          </StackPanel>
        </Border>

        <DockPanel>
          <Button DockPanel.Dock="Right"
                  Content="{Binding ButtonClear}"
                  Command="{Binding ClearAllCommand}"/>
          <TextBlock Text="{Binding LabelFilesCount}"
                     Foreground="{DynamicResource TextPrimaryBrush}"
                     VerticalAlignment="Center"/>
        </DockPanel>

        <Border BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="4"
                MinHeight="80"
                MaxHeight="200"
                Background="{DynamicResource BgCardBrush}">
          <ScrollViewer>
            <ItemsControl ItemsSource="{Binding Files}">
              <ItemsControl.ItemTemplate>
                <DataTemplate DataType="vm:SelectedFileItem">
                  <Grid ColumnDefinitions="Auto,*,Auto,Auto" Margin="6,4">
                    <TextBlock Grid.Column="0"
                               Text="📄"
                               FontSize="14"
                               Margin="0,0,8,0"/>
                    <TextBlock Grid.Column="1"
                               Text="{Binding DisplayName}"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"/>
                    <TextBlock Grid.Column="2"
                               Text="{Binding DisplaySize}"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center"
                               Margin="8,0"/>
                    <Button Grid.Column="3"
                            Width="26" Height="26"
                            Padding="0"
                            Classes="Danger"
                            Command="{Binding $parent[ItemsControl].((vm:ZipViewModel)DataContext).RemoveFileCommand}"
                            CommandParameter="{Binding}"
                            ToolTip.Tip="{Binding $parent[ItemsControl].((vm:ZipViewModel)DataContext).TooltipRemoveFile}">
                      <TextBlock Text="✕"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center"
                                 TextAlignment="Center"
                                 Margin="0,0,0,1"/>
                    </Button>
                  </Grid>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
        </Border>

        <Border BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="4"
                Padding="12"
                Background="{DynamicResource BgCardBrush}">
          <StackPanel Spacing="10">

            <!-- Cifrado: disponible en ambos modos -->
            <StackPanel Spacing="6">
              <CheckBox Content="{Binding LabelEncryption}"
                        IsChecked="{Binding IsEncryptionEnabled}"/>

              <StackPanel Orientation="Horizontal"
                          Spacing="8"
                          IsVisible="{Binding IsEncryptionEnabled}"
                          Margin="24,0,0,0">
                <Button Command="{Binding GeneratePasswordCommand}"
                        Width="32" Height="32"
                        Padding="0"
                        ToolTip.Tip="{Binding TooltipGeneratePassword}">
                  <TextBlock Text="🔑" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Button>
                <TextBox Text="{Binding Password}"
                         PasswordChar="{Binding PasswordCharDisplay}"
                         Width="240"
                         Watermark="{Binding LabelPasswordPlaceholder}"/>
                <Button Command="{Binding CopyPasswordCommand}"
                        Width="32" Height="32"
                        Padding="0"
                        ToolTip.Tip="{Binding TooltipCopyPassword}">
                  <TextBlock Text="📋" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Button>
                <ToggleButton IsChecked="{Binding IsPasswordVisible}"
                              Width="32" Height="32"
                              Padding="0"
                              ToolTip.Tip="{Binding TooltipTogglePassword}">
                  <TextBlock Text="👁" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </ToggleButton>
              </StackPanel>
            </StackPanel>

            <!-- Opciones técnicas: solo en modo avanzado -->
            <StackPanel Spacing="10" IsVisible="{Binding !IsSimpleMode}">

              <Separator Background="{DynamicResource BorderBrush}"/>

              <TextBlock Text="{Binding LabelOptions}"
                         FontWeight="SemiBold"
                         Foreground="{DynamicResource TextPrimaryBrush}"/>

              <DockPanel>
                <TextBlock Text="{Binding LabelCompression}"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           VerticalAlignment="Center"
                           Width="180"/>
                <ComboBox ItemsSource="{Binding AvailableLevels}"
                          SelectedItem="{Binding SelectedCompression}"
                          Width="250"
                          HorizontalAlignment="Left">
                  <ComboBox.ItemTemplate>
                    <DataTemplate>
                      <TextBlock Text="{Binding Name}"/>
                    </DataTemplate>
                  </ComboBox.ItemTemplate>
                </ComboBox>
              </DockPanel>

              <DockPanel>
                <TextBlock Text="{Binding LabelHashes}"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           VerticalAlignment="Center"
                           Width="180"/>
                <StackPanel Orientation="Horizontal" Spacing="12">
                  <CheckBox Content="MD5" IsChecked="{Binding UseMd5}"/>
                  <CheckBox Content="SHA-1" IsChecked="{Binding UseSha1}"/>
                  <CheckBox Content="SHA-256" IsChecked="{Binding UseSha256}"/>
                  <CheckBox Content="SHA-512" IsChecked="{Binding UseSha512}"/>
                </StackPanel>
              </DockPanel>

              <StackPanel Spacing="6">
                <CheckBox Content="{Binding LabelSplit}"
                          IsChecked="{Binding IsSplitEnabled}"/>

                <StackPanel Orientation="Horizontal"
                            Spacing="8"
                            IsVisible="{Binding IsSplitEnabled}"
                            Margin="24,0,0,0">
                  <TextBlock Text="{Binding LabelSplitSize}"
                             Foreground="{DynamicResource TextSecondaryBrush}"
                             VerticalAlignment="Center"/>
                  <ComboBox ItemsSource="{Binding AvailableSplitSizes}"
                            SelectedItem="{Binding SelectedSplitSize}"
                            Width="160">
                    <ComboBox.ItemTemplate>
                      <DataTemplate>
                        <TextBlock Text="{Binding Name}"/>
                      </DataTemplate>
                    </ComboBox.ItemTemplate>
                  </ComboBox>
                  <TextBox Text="{Binding CustomSplitMb}"
                           Width="120"
                           Watermark="{Binding LabelSplitCustom}"
                           VerticalContentAlignment="Center"/>
                </StackPanel>
              </StackPanel>
            </StackPanel>
          </StackPanel>
        </Border>

        <StackPanel Spacing="4">
          <TextBlock Text="{Binding LabelOutput}"
                     Foreground="{DynamicResource TextSecondaryBrush}"/>
          <Grid ColumnDefinitions="*,Auto">
            <TextBox Grid.Column="0"
                     Text="{Binding OutputPath}"
                     Height="32"
                     VerticalContentAlignment="Center"/>
            <Button Grid.Column="1"
                    Content="..."
                    Click="OnBrowseOutputClick"
                    Width="40" Height="32"
                    Padding="0"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    Margin="6,0,0,0"/>
          </Grid>
        </StackPanel>

        <ProgressBar Minimum="0" Maximum="100"
                     Value="{Binding ProgressPercent}"
                     Height="8"
                     IsVisible="{Binding IsProcessing}"
                     Foreground="{DynamicResource ProgressFillBrush}"
                     Background="{DynamicResource ProgressBgBrush}"/>

        <Grid ColumnDefinitions="*,Auto,Auto" IsVisible="{Binding IsProcessing}">
          <TextBlock Grid.Column="0"
                     Text="{Binding ProgressDetail}"
                     Foreground="{DynamicResource TextSecondaryBrush}"
                     FontSize="11"
                     VerticalAlignment="Center"/>
          <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4" Margin="12,0">
            <TextBlock Text="{Binding LabelElapsed}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"/>
            <TextBlock Text="{Binding ElapsedTime}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="11" FontWeight="SemiBold" FontFamily="Consolas,monospace"/>
          </StackPanel>
          <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4">
            <TextBlock Text="{Binding LabelRemaining}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"/>
            <TextBlock Text="{Binding RemainingTime}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="11" FontWeight="SemiBold" FontFamily="Consolas,monospace"/>
          </StackPanel>
        </Grid>

        <TextBlock Text="{Binding StatusMessage}"
                   Foreground="{DynamicResource TextSecondaryBrush}"/>

        <StackPanel Orientation="Horizontal"
                    Spacing="8"
                    HorizontalAlignment="Center">
          <Button Content="{Binding ButtonPack}"
                  Command="{Binding CompressCommand}"
                  Background="{DynamicResource AccentBrush}"
                  Foreground="White"
                  FontSize="15"
                  Padding="28,10"
                  IsEnabled="{Binding !IsProcessing}"/>
          <Button Content="{Binding ButtonCancel}"
                  Command="{Binding CompressCancelCommand}"
                  IsVisible="{Binding IsProcessing}"
                  Padding="20,8"/>
        </StackPanel>

      </StackPanel>
    </Panel>
  </ScrollViewer>
</UserControl>
