<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:ForZip.GUI.ViewModels"
             x:Class="ForZip.GUI.Views.ZipView"
             x:DataType="vm:ZipViewModel"
             DragDrop.AllowDrop="True">

  <ScrollViewer>
    <StackPanel Spacing="12" Margin="4">

      <TextBlock Text="{Binding Title}"
                 FontSize="16" FontWeight="SemiBold"
                 Foreground="{DynamicResource TextPrimaryBrush}"/>

      <Border x:Name="DropZone"
              BorderBrush="{DynamicResource BorderBrush}"
              BorderThickness="1"
              Background="Transparent"
              CornerRadius="4"
              Padding="24"
              MinHeight="100">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="4">
          <TextBlock Text="{Binding LabelDropZone}"
                     Foreground="{DynamicResource TextSecondaryBrush}"
                     HorizontalAlignment="Center"
                     TextAlignment="Center"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="8" Margin="0,8,0,0">
              <Button x:Name="BrowseFilesButton"
                      Content="Archivos..."
                      Click="OnBrowseFilesClick"/>
              <Button x:Name="BrowseFolderButton"
                      Content="Carpeta..."
                      Click="OnBrowseFolderClick"/>
            </StackPanel>
        </StackPanel>
      </Border>

      <DockPanel>
        <Button DockPanel.Dock="Right"
                Content="{Binding ButtonClear}"
                Command="{Binding ClearAllCommand}"/>
        <TextBlock Text="{Binding LabelFilesCount}"
                   Foreground="{DynamicResource TextPrimaryBrush}"
                   VerticalAlignment="Center"/>
      </DockPanel>

      <Border BorderBrush="{DynamicResource BorderBrush}"
              BorderThickness="1"
              CornerRadius="4"
              MinHeight="80"
              MaxHeight="200"
              Background="{DynamicResource BgCardBrush}">
        <ScrollViewer>
          <ItemsControl ItemsSource="{Binding Files}">
            <ItemsControl.ItemTemplate>
              <DataTemplate DataType="vm:SelectedFileItem">
                <Grid ColumnDefinitions="Auto,*,Auto,Auto" Margin="6,4">
                  <TextBlock Grid.Column="0"
                             Text="📄"
                             FontSize="14"
                             Margin="0,0,8,0"/>
                  <TextBlock Grid.Column="1"
                             Text="{Binding DisplayName}"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             VerticalAlignment="Center"
                             TextTrimming="CharacterEllipsis"/>
                  <TextBlock Grid.Column="2"
                             Text="{Binding DisplaySize}"
                             Foreground="{DynamicResource TextSecondaryBrush}"
                             VerticalAlignment="Center"
                             Margin="8,0"/>
                  <Button Grid.Column="3"
                          Width="26" Height="26"
                          Padding="0"
                          Classes="Danger"
                          Command="{Binding $parent[ItemsControl].((vm:ZipViewModel)DataContext).RemoveFileCommand}"
                          CommandParameter="{Binding}"
                          ToolTip.Tip="Quitar archivo">
                    <TextBlock Text="✕" 
                               HorizontalAlignment="Center" 
                               VerticalAlignment="Center" 
                               TextAlignment="Center"
                               Margin="0,0,0,1"/>
                  </Button>
                </Grid>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>
      </Border>

      <Border BorderBrush="{DynamicResource BorderBrush}"
              BorderThickness="1"
              CornerRadius="4"
              Padding="12"
              Background="{DynamicResource BgCardBrush}">
        <StackPanel Spacing="10">
          <TextBlock Text="{Binding LabelOptions}"
                     FontWeight="SemiBold"
                     Foreground="{DynamicResource TextPrimaryBrush}"/>

          <DockPanel>
            <TextBlock Text="{Binding LabelCompression}"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       VerticalAlignment="Center"
                       Width="180"/>
            <ComboBox ItemsSource="{Binding AvailableLevels}"
                      SelectedItem="{Binding SelectedCompression}"
                      Width="250"
                      HorizontalAlignment="Left">
              <ComboBox.ItemTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding Name}"/>
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
          </DockPanel>

          <StackPanel Spacing="6">
            <CheckBox Content="Cifrado AES-256"
                      IsChecked="{Binding IsEncryptionEnabled}"/>
            
            <StackPanel Orientation="Horizontal" 
                        Spacing="8" 
                        IsVisible="{Binding IsEncryptionEnabled}"
                        Margin="24,0,0,0">
              <Button Command="{Binding GeneratePasswordCommand}"
                      Width="32" Height="32"
                      Padding="0"
                      ToolTip.Tip="Generar contraseña segura">
                <TextBlock Text="🔑" HorizontalAlignment="Center" VerticalAlignment="Center"/>
              </Button>
              <TextBox Text="{Binding Password}"
                       PasswordChar="{Binding PasswordCharDisplay}"
                       Width="240"
                       Watermark="Ingrese la contraseña..."/>
              <Button Command="{Binding CopyPasswordCommand}"
                      Width="32" Height="32"
                      Padding="0"
                      ToolTip.Tip="Copiar al portapapeles">
                <TextBlock Text="📋" HorizontalAlignment="Center" VerticalAlignment="Center"/>
              </Button>
              <ToggleButton IsChecked="{Binding IsPasswordVisible}"
                            Width="32" Height="32"
                            Padding="0"
                            ToolTip.Tip="Mostrar/Ocultar contraseña">
                <TextBlock Text="👁" HorizontalAlignment="Center" VerticalAlignment="Center"/>
              </ToggleButton>
            </StackPanel>
          </StackPanel>

          <DockPanel>
            <TextBlock Text="{Binding LabelHashes}"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       VerticalAlignment="Center"
                       Width="180"/>
            <StackPanel Orientation="Horizontal" Spacing="12">
              <CheckBox Content="MD5" IsChecked="{Binding UseMd5}"/>
              <CheckBox Content="SHA-1" IsChecked="{Binding UseSha1}"/>
              <CheckBox Content="SHA-256" IsChecked="{Binding UseSha256}"/>
              <CheckBox Content="SHA-512" IsChecked="{Binding UseSha512}"/>
            </StackPanel>
          </DockPanel>
        </StackPanel>
      </Border>

      <StackPanel Spacing="4">
        <TextBlock Text="{Binding LabelOutput}"
                   Foreground="{DynamicResource TextSecondaryBrush}"/>
        <Grid ColumnDefinitions="*,Auto">
          <TextBox Grid.Column="0" 
                   Text="{Binding OutputPath}" 
                   Height="32"
                   VerticalContentAlignment="Center"/>
          <Button Grid.Column="1"
                  Content="..."
                  Click="OnBrowseOutputClick"
                  Width="40" Height="32"
                  Padding="0"
                  HorizontalContentAlignment="Center"
                  VerticalContentAlignment="Center"
                  Margin="6,0,0,0"/>
        </Grid>
      </StackPanel>

      <ProgressBar Minimum="0" Maximum="100"
                   Value="{Binding ProgressPercent}"
                   Height="8"
                   IsVisible="{Binding IsProcessing}"
                   Foreground="{DynamicResource ProgressFillBrush}"
                   Background="{DynamicResource ProgressBgBrush}"/>

      <Grid ColumnDefinitions="*,Auto,Auto" IsVisible="{Binding IsProcessing}">
        <TextBlock Grid.Column="0" 
                   Text="{Binding ProgressDetail}"
                   Foreground="{DynamicResource TextSecondaryBrush}"
                   FontSize="11"
                   VerticalAlignment="Center"/>
        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4" Margin="12,0">
          <TextBlock Text="Transcurrido:" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"/>
          <TextBlock Text="{Binding ElapsedTime}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="11" FontWeight="SemiBold" FontFamily="Consolas,monospace"/>
        </StackPanel>
        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4">
          <TextBlock Text="Restante:" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"/>
          <TextBlock Text="{Binding RemainingTime}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="11" FontWeight="SemiBold" FontFamily="Consolas,monospace"/>
        </StackPanel>
      </Grid>

      <TextBlock Text="{Binding StatusMessage}"
                 Foreground="{DynamicResource TextSecondaryBrush}"/>

      <StackPanel Orientation="Horizontal"
                  Spacing="8"
                  HorizontalAlignment="Center">
        <Button Content="{Binding ButtonPack}"
                Command="{Binding CompressCommand}"
                Background="{DynamicResource AccentBrush}"
                Foreground="White"
                Padding="20,8"
                IsEnabled="{Binding !IsProcessing}"/>
        <Button Content="{Binding ButtonCancel}"
                Command="{Binding CompressCancelCommand}"
                IsVisible="{Binding IsProcessing}"
                Padding="20,8"/>
      </StackPanel>

    </StackPanel>
  </ScrollViewer>
</UserControl>
