<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:ForZip.GUI.ViewModels"
        x:Class="ForZip.GUI.Views.OperatorConfirmationView"
        x:DataType="vm:OperatorConfirmationViewModel"
        Title="Confirmar Datos del Operador"
        Icon="avares://ForZip.GUI/Assets/ForZip.ico"
        Width="480" Height="520"
        WindowStartupLocation="CenterOwner"
        SystemDecorations="Full"
        CanResize="False"
        Background="{DynamicResource BgSecondaryBrush}">

  <Grid RowDefinitions="Auto,*,Auto" Margin="24,24,24,16">
    
    <StackPanel Grid.Row="0" Spacing="8" Margin="0,0,0,20">
      <TextBlock Text="{DynamicResource confirm_operator_title}"
                 FontSize="20" FontWeight="Bold"
                 Foreground="{DynamicResource AccentBrush}"/>
      <TextBlock Text="{DynamicResource confirm_operator_msg}"
                 TextWrapping="Wrap"
                 Foreground="{DynamicResource TextSecondaryBrush}"/>
    </StackPanel>

    <ScrollViewer Grid.Row="1" Margin="0,0,0,16">
      <Border Padding="0,0,16,0">
        <StackPanel Spacing="16">
          <StackPanel Spacing="6">
            <TextBlock Text="{DynamicResource report_op_name}" 
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       FontWeight="SemiBold"/>
            <TextBox Text="{Binding Name}" Watermark="Ej: Perito Juan Pérez"/>
          </StackPanel>
          
          <StackPanel Spacing="6">
            <TextBlock Text="{DynamicResource report_op_title}" 
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       FontWeight="SemiBold"/>
            <TextBox Text="{Binding Title}" Watermark="Ej: Especialista en Informática Forense"/>
          </StackPanel>

          <StackPanel Spacing="6">
            <TextBlock Text="{DynamicResource report_op_org}" 
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       FontWeight="SemiBold"/>
            <TextBox Text="{Binding Organization}" Watermark="Ej: Policía Científica"/>
          </StackPanel>

          <StackPanel Spacing="6">
            <TextBlock Text="{DynamicResource report_op_email}" 
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       FontWeight="SemiBold"/>
            <TextBox Text="{Binding Email}" Watermark="ejemplo@email.com"/>
          </StackPanel>

          <StackPanel Spacing="6">
            <TextBlock Text="{DynamicResource report_op_phone}" 
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       FontWeight="SemiBold"/>
            <TextBox Text="{Binding Phone}" Watermark="+54 9 ..."/>
          </StackPanel>

          <CheckBox Content="Generar archivo de hash externo (.sha256)"
                    IsChecked="{Binding GenerateExternalHash}"
                    Margin="0,8,0,0"/>
        </StackPanel>
      </Border>
    </ScrollViewer>

    <Border Grid.Row="2" 
            BorderBrush="{DynamicResource BorderBrush}" 
            BorderThickness="0,1,0,0" 
            Padding="0,16,0,0">
      <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Right">
        <Button Content="{DynamicResource cancel}"
                Width="100"
                Click="OnCancelClick"/>
        <Button Content="{DynamicResource confirm_generate}"
                Padding="16,8"
                Background="{DynamicResource AccentBrush}"
                Foreground="White"
                Command="{Binding ConfirmCommand}"
                Click="OnConfirmClick"/>
      </StackPanel>
    </Border>
    
  </Grid>
</Window>
