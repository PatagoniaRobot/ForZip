<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:ForZip.GUI.ViewModels"
             xmlns:interfaces="clr-namespace:ForZip.Core.Interfaces;assembly=ForZip.Core"
             x:Class="ForZip.GUI.Views.LogConsoleView"
             x:DataType="vm:LogConsoleViewModel">

  <Border BorderBrush="{DynamicResource BorderBrush}"
          BorderThickness="0,1,0,0"
          Background="#0C0E14">
    <Grid RowDefinitions="Auto,*">
      
      <!-- Header -->
      <Border Grid.Row="0" 
              Background="#161922" 
              Height="32" 
              Padding="12,0">
        <DockPanel>
          <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
            <Button Content="📥" 
                    Width="24" Height="24" Padding="0"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    Click="OnExportLogClick"
                    ToolTip.Tip="Exportar bitácora a archivo"/>
            <Button Content="✕" 
                    Width="24" Height="24" Padding="0"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    Command="{Binding ClearCommand}"
                    ToolTip.Tip="Limpiar bitácora"/>
          </StackPanel>
          <ToggleButton DockPanel.Dock="Left"
                        IsChecked="{Binding IsExpanded}"
                        Content="BITÁCORA DE ACTIVIDAD"
                        FontSize="10" FontWeight="Bold"
                        Foreground="#8A9199"
                        Padding="0" Background="Transparent" BorderThickness="0"/>
        </DockPanel>
      </Border>

      <!-- Content -->
      <Border Grid.Row="1" IsVisible="{Binding IsExpanded}" Height="160">
        <ListBox ItemsSource="{Binding Entries}"
                 Background="Transparent"
                 BorderThickness="0"
                 Padding="8,4"
                 x:Name="LogList">
          <ListBox.Styles>
            <Style Selector="ListBoxItem">
              <Setter Property="Padding" Value="0,1"/>
              <Setter Property="MinHeight" Value="0"/>
            </Style>
          </ListBox.Styles>
          <ListBox.ItemTemplate>
            <DataTemplate DataType="interfaces:LogEntry">
              <Grid ColumnDefinitions="Auto,Auto,*" Margin="0,0">
                <TextBlock Grid.Column="0" 
                           Text="{Binding Timestamp, StringFormat='[{0:HH:mm:ss}]'}" 
                           Foreground="#5C6370"
                           FontFamily="Consolas,monospace"
                           FontSize="11" Margin="0,0,10,0"/>
                <TextBlock Grid.Column="1" 
                           Text="{Binding Level, StringFormat='{}{0}:'}" 
                           Width="65"
                           FontFamily="Consolas,monospace"
                           FontSize="11" FontWeight="Bold"
                           Margin="0,0,8,0">
                  <TextBlock.Styles>
                    <Style Selector="TextBlock[Text='Info:']">
                      <Setter Property="Foreground" Value="#61AFEF"/>
                    </Style>
                    <Style Selector="TextBlock[Text='Success:']">
                      <Setter Property="Foreground" Value="#98C379"/>
                    </Style>
                    <Style Selector="TextBlock[Text='Warning:']">
                      <Setter Property="Foreground" Value="#D19A66"/>
                    </Style>
                    <Style Selector="TextBlock[Text='Error:']">
                      <Setter Property="Foreground" Value="#E06C75"/>
                    </Style>
                  </TextBlock.Styles>
                </TextBlock>
                <TextBlock Grid.Column="2" 
                           Text="{Binding Message}" 
                           FontFamily="Consolas,monospace"
                           FontSize="11"
                           TextWrapping="Wrap"
                           Foreground="#ABB2BF"/>
              </Grid>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </Border>
    </Grid>
  </Border>
</UserControl>
