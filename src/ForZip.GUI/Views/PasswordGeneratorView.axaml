<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:ForZip.GUI.ViewModels"
             x:Class="ForZip.GUI.Views.PasswordGeneratorView"
             x:DataType="vm:PasswordGeneratorViewModel">

  <ScrollViewer>
    <StackPanel Spacing="14" Margin="4">

      <TextBlock Text="GENERADOR DE CONTRASEÑAS"
                 FontSize="16" FontWeight="SemiBold"
                 Foreground="{DynamicResource TextPrimaryBrush}"/>

      <Border BorderBrush="{DynamicResource BorderBrush}"
              BorderThickness="1"
              CornerRadius="4"
              Padding="20"
              Background="{DynamicResource BgCardBrush}">
        <TextBox Text="{Binding GeneratedPassword}"
                 FontFamily="Consolas,monospace"
                 FontSize="16"
                 IsReadOnly="True"
                 Background="Transparent"
                 BorderThickness="0"
                 HorizontalAlignment="Stretch"/>
      </Border>

      <DockPanel>
        <TextBlock DockPanel.Dock="Right"
                   Text="{Binding EntropyBits, StringFormat='{}{0:0.0} bits — '}"
                   Foreground="{DynamicResource TextSecondaryBrush}"
                   FontSize="11"
                   VerticalAlignment="Center"/>
        <TextBlock DockPanel.Dock="Right"
                   Text="{Binding EntropyLabel}"
                   Foreground="{DynamicResource AccentBrush}"
                   FontSize="11" FontWeight="SemiBold"
                   VerticalAlignment="Center"
                   Margin="0,0,8,0"/>
        <ProgressBar Minimum="0" Maximum="128"
                     Value="{Binding EntropyBits}"
                     Height="8"
                     Foreground="{DynamicResource ProgressFillBrush}"
                     Background="{DynamicResource ProgressBgBrush}"/>
      </DockPanel>

      <Border BorderBrush="{DynamicResource BorderBrush}"
              BorderThickness="1"
              CornerRadius="4"
              Padding="16"
              Background="{DynamicResource BgCardBrush}">
        <StackPanel Spacing="10">
          <TextBlock Text="Opciones"
                     FontWeight="SemiBold"
                     Foreground="{DynamicResource TextPrimaryBrush}"/>

          <DockPanel>
            <TextBlock DockPanel.Dock="Left"
                       Text="Longitud:"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       VerticalAlignment="Center"
                       Width="100"/>
            <TextBlock DockPanel.Dock="Right"
                       Text="{Binding Length}"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       VerticalAlignment="Center"
                       Width="40"
                       TextAlignment="Right"/>
            <Slider Minimum="8" Maximum="128"
                    Value="{Binding Length}"
                    TickFrequency="1"
                    IsSnapToTickEnabled="True"/>
          </DockPanel>

          <CheckBox Content="Mayúsculas (A-Z)" IsChecked="{Binding IncludeUppercase}"/>
          <CheckBox Content="Minúsculas (a-z)" IsChecked="{Binding IncludeLowercase}"/>
          <CheckBox Content="Dígitos (0-9)" IsChecked="{Binding IncludeDigits}"/>
          <CheckBox Content="Símbolos (!@#$%^&amp;*...)" IsChecked="{Binding IncludeSymbols}"/>
          <CheckBox Content="Excluir ambiguos (0 O o I l 1 |)" IsChecked="{Binding ExcludeAmbiguous}"/>
        </StackPanel>
      </Border>

      <TextBlock Text="{Binding StatusMessage}"
                 Foreground="{DynamicResource TextSecondaryBrush}"
                 HorizontalAlignment="Center"/>

      <StackPanel Orientation="Horizontal"
                  Spacing="8"
                  HorizontalAlignment="Center">
        <Button Content="Generar nueva"
                Command="{Binding GenerateCommand}"
                Background="{DynamicResource AccentBrush}"
                Foreground="White"
                Padding="20,8"/>
        <Button Content="📋 Copiar"
                Command="{Binding CopyCommand}"
                HorizontalContentAlignment="Center"
                VerticalContentAlignment="Center"
                Padding="20,8"/>
      </StackPanel>

    </StackPanel>
  </ScrollViewer>
</UserControl>
